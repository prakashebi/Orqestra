# ---------------------------------------------------------------
# Root-level environment overrides
# Copy this file to .env and fill in the values you need.
#   cp .env.example .env
# ---------------------------------------------------------------

# Search backend — "postgres" (default, no extra infra) or "opensearch"
SEARCH_BACKEND=postgres

# OpenSearch connection — only needed when SEARCH_BACKEND=opensearch
# Use "opensearch" as the host when running inside Docker Compose,
# or "localhost" when running the backend outside Docker.
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Admin@Orqestra1
