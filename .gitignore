# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local

# ── Python / Backend ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/
.env
*.env

# ── Alembic ───────────────────────────────────────────────────────────────────
