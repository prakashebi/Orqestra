*.pyc

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.swp
*.swo
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace

# ── Test / coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Docker ────────────────────────────────────────────────────────────────────
*.override.yml

# ── Uploads (runtime data) ────────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep
